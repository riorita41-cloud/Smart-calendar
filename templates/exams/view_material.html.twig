{% extends 'base.html.twig' %}

{% block title %}{{ material.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/materials.css') }}">
{% endblock %}

{% block body %}
<div class="material-view">
    <a href="{{ path('app_exams') }}" class="back-link">← Назад к экзаменам</a>
    
    <div class="material-header">
        <h1 class="material-title">{{ material.name }}</h1>
        <div class="material-meta">
            {% if material.fileType == 'manual' %}
                📝 Ручной ввод • {{ material.uploadedAt|date('d.m.Y H:i') }}
            {% else %}
                📄 {{ material.fileType|upper }} файл • {{ material.uploadedAt|date('d.m.Y H:i') }}
            {% endif %}
        </div>
    </div>
    
    {% if material.fileType == 'manual' %}
        <div class="material-content">
            {{ material.content }}
        </div>
    {% else %}
        <div class="material-content" style="text-align: center; padding: 60px 40px;">
            <p style="font-size: 18px; margin-bottom: 20px;">📄 Это файл {{ material.fileType|upper }}</p>
            <p style="color: #6B6B5E; margin-bottom: 30px;">Нажмите кнопку ниже чтобы скачать или открыть файл</p>
            <a href="{{ path('app_materials_view', {id: material.id}) }}" class="download-link" download>
                ⬇️ Скачать файл
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}