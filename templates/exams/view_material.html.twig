{% extends 'base.html.twig' %}

{% block title %}{{ material.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/materials.css') }}">
{% endblock %}

{% block body %}
<div class="material-view">
    <a href="{{ path('app_exams') }}" class="back-link">
        <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5"/>
            <path d="M12 19l-7-7 7-7"/>
        </svg>
        Назад к экзаменам
    </a>
    
    <div class="material-header">
        <h1 class="material-title">{{ material.name }}</h1>
        <div class="material-meta">
            <span class="meta-type">Текстовый материал</span>
            <span class="meta-date">{{ material.uploadedAt|date('d.m.Y H:i') }}</span>
        </div>
    </div>
    
    <div class="material-content">
        {{ material.content }}
    </div>
</div>
{% endblock %}