{% extends 'base.html.twig' %}

{% block title %}Экзамены{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/exams-dashboard.css') }}">
{% endblock %}

{% block body %}
<div class="exams-container">
    <h1 class="page-title">
        <svg class="page-icon" viewBox="0 0 24 24" width="36" height="36">
            <path fill="currentColor" d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
        </svg>
        Мои экзамены
    </h1>
    
    <div class="section">
        <div class="section-header">
            <h2 class="section-title">Список экзаменов</h2>
            <a href="{{ path('app_exam_new') }}" class="btn-add-exam">
                <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18">
                    <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                </svg>
                Добавить экзамен
            </a>
        </div>
        
        {% if exams|length > 0 %}
            {% for exam in exams %}
                <div class="exam-card">
                    <div class="exam-header">
                        <div class="exam-info">
                            <div class="exam-name">{{ exam.name }}</div>
                            <div class="exam-subject">{{ exam.subject }}</div>
                        </div>
                        <div class="exam-date">
                            <svg class="inline-icon" viewBox="0 0 24 24" width="18" height="18">
                                <path fill="currentColor" d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                            </svg>
                            {{ exam.examDate|date('d.m.Y') }}
                        </div>
                    </div>
                    
                    <div class="exam-schedule-info">
                        {% if exam.questionsPerDay > 0 %}
                            <div class="schedule-badge">
                                <svg class="badge-icon" viewBox="0 0 24 24" width="20" height="20">
                                    <path fill="currentColor" d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>
                                </svg>
                                <strong>{{ exam.questionsPerDay }} вопросов/день</strong>
                                <span class="schedule-details">
                                    ({{ exam.studyDaysFormatted|join(', ') }}, {{ exam.studyStartTime|date('H:i') }} – {{ exam.studyEndTime|date('H:i') }})
                                </span>
                            </div>
                            <a href="{{ path('app_exam_schedule', {id: exam.id}) }}" class="btn-view-schedule">
                                <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18">
                                    <path fill="currentColor" d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                                </svg>
                                Смотреть расписание
                            </a>
                        {% else %}
                            <div class="no-schedule">Расписание ещё не составлено</div>
                        {% endif %}
                    </div>

                    <div class="exam-actions">
                        <form method="post" action="{{ path('app_exam_generate_schedule', {id: exam.id}) }}" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('generate_schedule_' ~ exam.id) }}">
                            <button type="submit" class="btn-generate-schedule" onclick="return confirm('Составить новое расписание? Старое будет удалено.')">
                                <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18">
                                    <path fill="currentColor" d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L3.16 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                                </svg>
                                Составить расписание
                            </button>
                        </form>
                        
                        <form method="post" action="{{ path('app_exam_delete', {id: exam.id}) }}" class="inline-form" onsubmit="return confirm('Удалить экзамен?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_exam_' ~ exam.id) }}">
                            <button type="submit" class="btn-delete-exam">
                                <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18">
                                    <path fill="currentColor" d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                </svg>
                                Удалить
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="no-data">
                <p>У вас пока нет добавленных экзаменов</p>
                <a href="{{ path('app_exam_new') }}" class="btn-add">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18">
                        <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                    </svg>
                    Добавить первый экзамен
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}