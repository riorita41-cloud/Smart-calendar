{% extends 'base.html.twig' %}

{% block title %}Расписание - {{ exam.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/schedule.css') }}">
{% endblock %}

{% block body %}
<div class="schedule-page">
    <a href="{{ path('app_exams') }}" class="back-link">
        <svg class="back-icon" viewBox="0 0 24 24" width="18" height="18">
            <path fill="currentColor" d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
        </svg>
        Назад к экзаменам
    </a>
    
    <div class="schedule-header">
        <h1 class="schedule-title">Расписание подготовки к "{{ exam.name }}"</h1>
        <div class="schedule-summary">
            <div class="summary-item">
                <div class="summary-number">{{ exam.examDate|date('d.m.Y') }}</div>
                <div class="summary-label">Дата экзамена</div>
            </div>
            <div class="summary-item">
                <div class="summary-number">{{ schedules|length }}</div>
                <div class="summary-label">Дней подготовки</div>
            </div>
            <div class="summary-item">
                <div class="summary-number">{{ exam.questionsPerDay }}</div>
                <div class="summary-label">Вопросов в день</div>
            </div>
        </div>
    </div>

    {% if schedules|length > 0 %}
        <div class="timeline">
            {% for schedule in schedules %}
                <div class="timeline-item {% if schedule.isCompleted %}completed{% endif %}">
                    <div class="timeline-dot"></div>
                    <div class="timeline-date">
                        {{ schedule.studyDate|date('d F, D')|replace({
                            'January': 'января', 'February': 'февраля', 'March': 'марта', 
                            'April': 'апреля', 'May': 'мая', 'June': 'июня', 
                            'July': 'июля', 'August': 'августа', 'September': 'сентября', 
                            'October': 'октября', 'November': 'ноября', 'December': 'декабря',
                            'Mon': 'Пн', 'Tue': 'Вт', 'Wed': 'Ср', 'Thu': 'Чт', 
                            'Fri': 'Пт', 'Sat': 'Сб', 'Sun': 'Вс'
                        }) }}
                    </div>
                    <div class="timeline-time">
                        <svg class="time-icon" viewBox="0 0 24 24" width="16" height="16">
                            <path fill="currentColor" d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                        </svg>
                        {{ schedule.startTime|date('H:i') }} – {{ schedule.endTime|date('H:i') }}
                    </div>
                    <div class="timeline-task">
                        <svg class="task-icon" viewBox="0 0 24 24" width="16" height="16">
                            <path fill="currentColor" d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>
                        </svg>
                        <strong>{{ schedule.questionsCount }} вопросов</strong>
                        
                        {% if schedule.questionIds %}
                            <div class="questions-list">
                                {% for questionId in schedule.questionIds %}
                                    {% if allQuestions[questionId] is defined %}
                                        <div class="question-item">
                                            <span class="question-number">{{ loop.index }}.</span> 
                                            {{ allQuestions[questionId].text }}
                                            
                                            {% if allQuestions[questionId].answer %}
                                                <div class="question-answer">
                                                    <span class="answer-label">Ответ:</span> {{ allQuestions[questionId].answer }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    {% if not schedule.isCompleted %}
                        <form method="post" action="{{ path('app_schedule_complete', {id: schedule.id}) }}" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('schedule_action') }}">
                            <button type="submit" class="btn-complete">
                                <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16">
                                    <path fill="currentColor" d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                                </svg>
                                Отметить как выполненное
                            </button>
                        </form>
                    {% else %}
                        <div class="completed-actions">
                            <span class="completed-badge">
                                <svg class="badge-icon" viewBox="0 0 24 24" width="16" height="16">
                                    <path fill="currentColor" d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                                </svg>
                                Выполнено
                            </span>
                            <form method="post" action="{{ path('app_schedule_uncomplete', {id: schedule.id}) }}" class="inline-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('schedule_action') }}">
                                <button type="submit" class="btn-uncomplete">
                                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16">
                                        <path fill="currentColor" d="M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z"/>
                                    </svg>
                                    Вернуть в невыполненные
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="no-schedule">
            <h3>Расписание ещё не составлено</h3>
            <p>Нажмите кнопку "Составить расписание" на странице экзамена</p>
            <a href="{{ path('app_exams') }}" class="back-link">
                <svg class="back-icon" viewBox="0 0 24 24" width="16" height="16">
                    <path fill="currentColor" d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                </svg>
                Вернуться к экзаменам
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}