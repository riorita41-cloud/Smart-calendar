{% extends 'base.html.twig' %}

{% block title %}Мой аватар{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/avatar.css') }}">
{% endblock %}

{% block body %}

<div class="avatar-page">
    <h1 class="avatar-title">Настройка аватара</h1>
    
    <div id="avatar-data" 
         data-seed="{{ avatar.seed ?? app.user.email }}" 
         style="display:none;">
    </div>
    
    <div class="avatar-container">
        <div class="avatar-preview">
            <div id="avatar-img" class="avatar-dicebear">Загрузка...</div>
            <p style="color: #6B6B5E; margin-top: 15px;">DiceBear Adventurer</p>
        </div>
        
        <div class="avatar-form">
            <form method="post" action="{{ path('app_avatar_save') }}">
                <input type="hidden" name="seed" id="current-seed" value="{{ avatar.seed ?? app.user.email }}">
                
                <button type="button" class="btn-random" onclick="generateRandomAvatar()">
                     Сгенерировать случайный аватар
                </button>
                
                <div class="form-section">
                    <h3>Цвет кожи</h3>
                    <div class="color-picker">
                        {% for color in ['ffdbb4', 'edb98a', 'd08b5b', 'ae5d29', '7c3c16'] %}
                            <label class="color-option">
                                <input type="radio" name="skinColor" value="{{ color }}" class="avatar-option" {% if (avatar.skinColor ?? 'edb98a') == color %}checked{% endif %}>
                                <span class="color-circle" style="background: #{{ color }};"></span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
                
                <div class="form-section">
                    <h3>Причёска</h3>
                    <div class="option-group">
                        {% for i in 1..5 %}
                            <div class="option-item">
                                <input type="radio" name="hair" id="sh{{ i }}" value="short0{{ i }}" class="avatar-option" {% if (avatar.hairStyle ?? 'long01') == 'short0'~i %}checked{% endif %}>
                                <label for="sh{{ i }}">Короткая {{ i }}</label>
                            </div>
                        {% endfor %}
                        {% for i in 1..10 %}
                            <div class="option-item">
                                <input type="radio" name="hair" id="lo{{ i }}" value="long{{ i < 10 ? '0'~i : i }}" class="avatar-option" {% if (avatar.hairStyle ?? 'long01') == 'long'~(i < 10 ? '0'~i : i) %}checked{% endif %}>
                                <label for="lo{{ i }}">Длинная {{ i }}</label>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                
                <div class="form-section">
                    <h3>Цвет волос</h3>
                    <div class="color-picker">
                        {% for color in ['000000', '2c1b18', '724133', 'b58143', 'd9532f'] %}
                            <label class="color-option">
                                <input type="radio" name="hairColor" value="{{ color }}" class="avatar-option" {% if (avatar.hairColor ?? '724133') == color %}checked{% endif %}>
                                <span class="color-circle" style="background: #{{ color }};"></span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
                
                <button type="submit" class="btn-save">Сохранить аватар</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module" src="{{ asset('js/avatar-editor.js') }}"></script>
{% endblock %}