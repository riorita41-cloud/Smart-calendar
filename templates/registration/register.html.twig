{% extends 'base.html.twig' %}

{% block title %}Регистрация{% endblock %}

{# Убираем меню и включаем центрирование #}
{% block sidebar %}{% endblock %}
{% block body_class %}full-width-layout{% endblock %}

{% block body %}
<div class="register-container">
    <div class="register-header">
        <h1 class="register-title">Регистрация</h1>
    </div>
    
    {% for message in app.flashes('error') %}
        <div class="alert-error">{{ message }}</div>
    {% endfor %}
    
    {{ form_start(registrationForm) }}
        <div class="form-group">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email, {'attr': {'autocomplete': 'email'}}) }}
        </div>
        
        <div class="form-group">
            {{ form_label(registrationForm.plainPassword, 'Пароль') }}
            {{ form_widget(registrationForm.plainPassword, {'attr': {'autocomplete': 'new-password'}}) }}
        </div>

        {# Заменяем "Agree terms" на "Запомнить меня" или нужный чекбокс #}
        <div class="remember-me">
            {{ form_widget(registrationForm.agreeTerms) }}
            <label for="registration_form_agreeTerms">Я согласен с условиями</label>
        </div>
        
        <button type="submit" class="btn-register">Зарегистрироваться</button>
    {{ form_end(registrationForm) }}
    
    <div class="login-link">
        Уже есть аккаунт? <a href="{{ path('app_login') }}">Войти</a>
    </div>
</div>
{% endblock %}