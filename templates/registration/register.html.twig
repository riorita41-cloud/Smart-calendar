{% extends 'base.html.twig' %}

{% block title %}Регистрация{% endblock %}

{% block sidebar %}{% endblock %}
{% block body_class %}full-width-layout{% endblock %}

{% block body %}
<div class="register-container">
    <div class="register-header">
        <h1 class="register-title">Регистрация</h1>
    </div>
    
    {% for type in ['success', 'error'] %}
        {% for message in app.flashes(type) %}
            <div class="alert-{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    
    {{ form_errors(registrationForm) }}
    
    {{ form_start(registrationForm) }}
        <div class="form-group">
            {{ form_label(registrationForm.email, 'Email') }}
            {{ form_widget(registrationForm.email, {'attr': {'autocomplete': 'email', 'class': 'form-control', 'maxlength': '180'}}) }}
            {{ form_errors(registrationForm.email) }}
        </div>
        
        <div class="form-group">
            {{ form_label(registrationForm.plainPassword, 'Пароль') }}
            {{ form_widget(registrationForm.plainPassword, {'attr': {'autocomplete': 'new-password', 'class': 'form-control', 'maxlength': '180'}}) }}
            {{ form_errors(registrationForm.plainPassword) }}
        </div>

        <div class="form-group remember-me">
            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'checkbox-control'}}) }}
            {{ form_label(registrationForm.agreeTerms, 'Я согласен с условиями') }}
            {{ form_errors(registrationForm.agreeTerms) }}
        </div>
        
        <button type="submit" class="btn-register">Зарегистрироваться</button>
    {{ form_end(registrationForm) }}
    
    <div class="login-link">
        Уже есть аккаунт? <a href="{{ path('app_login') }}">Войти</a>
    </div>
</div>
{% endblock %}