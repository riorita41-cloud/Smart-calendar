{% extends 'base.html.twig' %}

{% block title %}Главная - Умный Календарь{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
{% endblock %}

{% block body %}
{# Скрытый блок с данными для JS #}
<div id="avatar-config" 
     data-seed="{{ avatar.seed ?: app.user.email }}"
     data-skin="{{ avatar.skinColor ?: 'edb98a' }}"
     data-hair-color="{{ avatar.hairColor ?: '724133' }}"
     data-hair-style="{{ avatar.hairStyle ?: 'long01' }}"
     style="display:none;">
</div>

<div class="dashboard-grid">
    <div class="card task-of-day">
        <h2 class="task-title">Задача дня</h2>
        {% if todayTasks|length > 0 %}
            <div class="task-description">
                {% for task in todayTasks %}{{ task.title }}{% if not loop.last %}, {% endif %}{% endfor %}
            </div>
            <div class="progress-container">
                <div class="progress-bar"><div class="progress-fill" style="width: {{ progress }}%"></div></div>
                <div class="progress-text">{{ progress }}% выполнено</div>
            </div>
        {% else %}
            <div class="no-data">На сегодня задач нет</div>
        {% endif %}
    </div>

    <div class="stats-row">
        <div class="card timer-card">
            <h3 class="timer-title">Таймер подготовки</h3>
            <div class="timer-circle">
                <svg width="150" height="150">
                    <circle class="bg" cx="75" cy="75" r="65"></circle>
                    <circle class="fill" cx="75" cy="75" r="65" stroke-dasharray="408.4" stroke-dashoffset="408.4"></circle>
                </svg>
                <div class="timer-display" id="timer">45:00</div>
            </div>
            <button class="btn-start" id="startTimer">Начать</button>
        </div>
        
        <div class="card days-card">
            <h3 class="days-title">Дней до экзамена</h3>
            <div class="days-circle">
                <div class="days-number">{{ daysToExam ?? '-' }}</div>
            </div>
        </div>
    </div>
    
    <div class="card avatar-card">
        <h3 class="avatar-title">Ваш аватар</h3>
        <div class="avatar-circle" id="user-avatar"></div>
        <div class="level-info">
            <div class="level-text">Уровень 5</div>
            <div class="xp-text">1,240 / 1,500 XP</div>
            <div class="xp-bar"><div class="xp-fill" style="width: 82.67%"></div></div>
        </div>
        <a href="{{ path('app_avatar') }}" style="color: #4A5D3A;">Настроить аватар</a>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module" src="{{ asset('js/dashboard.js') }}"></script>
{% endblock %}