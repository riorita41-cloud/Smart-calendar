{% extends 'base.html.twig' %}

{% block title %}Главная - Умный Календарь{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
{% endblock %}

{% block body %}
<div id="avatar-config" 
     data-seed="{{ (avatar.seed ?? app.user?.email ?? 'default@example.com')|e('html_attr') }}"
     data-skin="{{ (avatar.skinColor ?? 'edb98a')|e('html_attr') }}"
     data-hair-color="{{ (avatar.hairColor ?? '724133')|e('html_attr') }}"
     data-hair-style="{{ (avatar.hairStyle ?? 'long01')|e('html_attr') }}"
     style="display:none;">
</div>

<div class="dashboard-grid">
    <div class="card task-of-day">
        <h2 class="task-title">Задачи на сегодня</h2>
        {% if todayTasks|length > 0 %}
            <div class="task-list-container">
                {% for task in todayTasks %}
                    <div class="task-list-item {% if task.isCompleted %}completed{% endif %}">
                        {{ task.title }}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="no-data">На сегодня задач нет</div>
        {% endif %}

        <div class="progress-section">
            {% if totalQuestions > 0 %}
                <div class="progress-container">
                    <div class="progress-bar"><div class="progress-fill" style="width: {{ progress }}%"></div></div>
                    <div class="progress-text">{{ progress }}%</div>
                </div>
                <div class="progress-title">Прогресс изучения вопросов</div>
            {% else %}
                <div class="no-data" style="padding: 10px;">Добавьте вопросы к экзаменам</div>
            {% endif %}
        </div>
    </div>

    <div class="stats-row">
        <div class="card timer-card">
            <h3 class="timer-title">Pomodoro Таймер</h3>
            
            <div class="timer-mode work" id="timer-mode">
                <span class="mode-text">Режим: Работа</span>
            </div>
            
            <div class="timer-display" id="timer-display">25:00</div>
            
            <div class="cycle-dots" id="cycle-dots">
                <span class="cycle-dot active"></span>
                <span class="cycle-dot"></span>
                <span class="cycle-dot"></span>
                <span class="cycle-dot"></span>
            </div>
            <div class="cycle-info" id="cycle-info">Сессия 1 из 4</div>
            
            <div class="timer-controls">
                <button id="start-btn" class="btn-start">Старт</button>
                <button id="pause-btn" class="btn-pause" style="display: none;">Пауза</button>
                <button id="reset-btn" class="btn-reset">Сброс</button>
            </div>
            
            <div class="timer-stats">
                <span>Сегодня завершено сессий: </span>
                <strong id="sessions-count">{{ todaySessionsCount }}</strong>
            </div>
            
            <div id="timer-message" class="timer-message" style="display: none;"></div>
        </div>
        
        <div class="card days-card">
            <h3 class="days-title">Дней до экзамена</h3>
            <div class="days-circle">
                <div class="days-number">{{ daysToExam ?? '-' }}</div>
            </div>
            {% if nearestExam %}
                <div class="days-exam-name">{{ nearestExam.name }}</div>
            {% endif %}
        </div>
    </div>
    
    <div class="card avatar-card">
        <h3 class="avatar-title">Ваш аватар</h3>
        <div class="avatar-circle" id="user-avatar"></div>
        
        <div class="level-info">
            <div class="level-text">Уровень {{ user.level }} — {{ currentTitle }}</div>
            <div class="xp-text">{{ user.xp }} / {{ nextLevelXp }} XP</div>
            <div class="xp-bar">
                <div class="xp-fill" style="width: {{ xpPercent }}%"></div>
            </div>
            <div class="streak-text">Серия дней: {{ user.streakDays }}</div>
        </div>

        <a href="{{ path('app_avatar') }}" class="btn-configure-avatar">Настроить аватар</a>

        {# БЛОК ИСТОРИИ АКТИВНОСТИ ТЕПЕРЬ НИЖЕ КНОПКИ #}
        {% if recentXpLogs is defined and recentXpLogs|length > 0 %}
            <div class="xp-history">
                <h4 class="xp-history-title">Последняя активность</h4>
                <div class="xp-history-list">
                    {% for log in recentXpLogs %}
                        <div class="xp-history-item">
                            <span class="xp-history-reason">{{ log.reasonText }}</span>
                            <span class="xp-history-amount">+{{ log.amount }} XP</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module" src="{{ asset('js/dashboard.js') }}"></script>
    <script src="{{ asset('js/pomodoro.js') }}"></script>
{% endblock %}