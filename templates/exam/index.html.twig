{% extends 'base.html.twig' %}

{% block title %}Мои экзамены{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/exams.css') }}">
{% endblock %}

{% block body %}
  
<div class="exams-page">
    <div class="exams-header">
        <h1 class="exams-title">Мои экзамены</h1>
        <a href="{{ path('app_exam_new') }}" class="btn-add">+ Добавить экзамен</a>
    </div>
    
    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    
    {% if exams|length > 0 %}
        {% for exam in exams %}
            <div class="exam-card">
                <div class="exam-info">
                    <h3>{{ exam.name }}</h3>
                    <div class="exam-meta">
                        <span class="icon"></span>{{ exam.subject }}
                    </div>
                    <div class="exam-meta">
                        <span class="icon"></span>{{ exam.examDate|date('d.m.Y') }}
                    </div>
                    <div class="exam-meta">
                        <span class="icon"></span>
                        {% set days = (exam.examDate|date('U') - 'now'|date('U')) / 86400 %}
                        {% if days > 0 %}
                            Осталось дней: {{ days|round(0, 'ceil') }}
                        {% else %}
                            Экзамен сегодня!
                        {% endif %}
                    </div>
                </div>
                
                <form method="post" action="{{ path('app_exam_delete', {id: exam.id}) }}" 
                      onsubmit="return confirm('Удалить экзамен?');">
                    
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_exam_' ~ exam.id) }}">
                    
                    <button type="submit" class="btn-delete">Удалить</button>
                </form>
            </div>
        {% endfor %}
    {% else %}
        <div class="empty-state">
            <div class="icon"></div>
            <p>У вас пока нет экзаменоЫв</p>
            <a href="{{ path('app_exam_new') }}" class="btn-add">Добавить первый экзамен</a>
        </div>
    {% endif %}
</div>
{% endblock %}Ы