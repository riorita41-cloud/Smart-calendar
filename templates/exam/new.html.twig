{% extends 'base.html.twig' %}

{% block title %}Добавить экзамен{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/exam-form.css') }}">
{% endblock %}

{% block body %}
<div class="form-page">
    <div class="form-container">
        <h1 class="form-title">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
                <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
            </svg>
            Новый экзамен
        </h1>
        
        {{ form_start(form) }}
            
            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.subject) }}
                {{ form_widget(form.subject) }}
                {{ form_errors(form.subject) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.examDate) }}
                {{ form_widget(form.examDate) }}
                {{ form_errors(form.examDate) }}
            </div>
            
            <div class="form-group">
                <label>Дни для занятий</label>
                <div class="days-selector">
                    {% for child in form.studyDays %}
                        {{ form_widget(child) }}
                        {{ form_label(child) }}
                    {% endfor %}
                </div>
                <div class="days-hint">Выберите дни, когда планируете готовиться к экзамену</div>
                {{ form_errors(form.studyDays) }}
            </div>
            
            <div class="form-group">
                <div class="time-section-title">
                    <span class="time-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                            <polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="2"/>
                        </svg>
                    </span>
                    Время занятий
                </div>
                <div class="time-selector">
                    <div class="time-input-wrapper">
                        <label for="{{ form.studyStartTime.vars.id }}">Начало</label>
                        {{ form_widget(form.studyStartTime) }}
                    </div>
                    <div class="time-separator">—</div>
                    <div class="time-input-wrapper">
                        <label for="{{ form.studyEndTime.vars.id }}">Окончание</label>
                        {{ form_widget(form.studyEndTime) }}
                    </div>
                </div>
                {{ form_errors(form.studyStartTime) }}
                {{ form_errors(form.studyEndTime) }}
            </div>
            
            <button type="submit" class="btn-submit">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Создать экзамен
            </button>
        {{ form_end(form) }}
        
                <div style="text-align: center; margin-top: 25px;">
            <a href="{{ path('app_exams') }}" class="btn-outline-secondary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 12H5M5 12l6 6M5 12l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Назад к списку
            </a>
        </div>
    </div>
</div>
{% endblock %}