{% extends 'base.html.twig' %}

{% block title %}Календарь подготовки{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/calendar.css') }}">
{% endblock %}

{% block body %}
<div class="calendar-page">
    <h1 class="calendar-title">Расписание подготовки</h1>
    <div class="calendar-container">
        <div class="calendar-main">
            <div class="calendar-card">
                <div class="month-header">
                    <a href="{{ path('app_calendar', {year: prevMonth.format('Y'), month: prevMonth.format('n')}) }}" class="month-nav">&lt;</a>
                    <div class="month-year-selector">
                        <button class="selector-btn" onclick="toggleDropdown('monthDropdown')">{{ monthTitle|split(' ')[0] }}</button>
                        <div id="monthDropdown" class="dropdown-menu">
                            {% for m in 1..12 %}
                                <a href="{{ path('app_calendar', {year: currentYear, month: m}) }}" class="dropdown-item {% if m == month %}active{% endif %}">
                                    {{ ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь', 'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'][m-1] }}
                                </a>
                            {% endfor %}
                        </div>
                        <button class="selector-btn" onclick="toggleDropdown('yearDropdown')">{{ currentYear }}</button>
                        <div id="yearDropdown" class="dropdown-menu">
                            {% for y in (currentYear - 5)..(currentYear + 5) %}
                                <a href="{{ path('app_calendar', {year: y, month: month}) }}" class="dropdown-item {% if y == currentYear %}active{% endif %}">{{ y }}</a>
                            {% endfor %}
                        </div>
                    </div>
                    <a href="{{ path('app_calendar', {year: nextMonth.format('Y'), month: nextMonth.format('n')}) }}" class="month-nav">&gt;</a>
                </div>
                <div class="weekdays">{% for day in ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'] %}<div class="weekday">{{ day }}</div>{% endfor %}</div>
                <div class="days-grid">
                    {% for i in 1..(firstDayOfWeek - 1) %}<div class="day-cell empty"></div>{% endfor %}
                    {% for day in 1..daysInMonth %}
                        {% set dateStr = currentYear ~ '-' ~ (month < 10 ? '0'~month : month) ~ '-' ~ (day < 10 ? '0'~day : day) %}
                        {% set dayTasks = tasksByDay[dateStr] ?? [] %}
                        <div class="day-cell {% if today.format('Y-m-d') == dateStr %}today{% endif %} {% if dateStr in examDates %}exam-day{% endif %}" 
                            onclick="openTaskModal('{{ dateStr }}')">
                            <span class="day-number">{{ day }}</span>
                            {% if dateStr in examDates %}
                                <div class="exam-label">{{ examByDate[dateStr] }}</div>
                            {% endif %}
                            {% if dayTasks is not empty %}<div class="task-dot"></div>{% endif %}
                            
                            <div class="day-tooltip">
                                <div class="tooltip-title">Задачи на {{ dateStr }}</div>
                                {% if dayTasks is empty %}
                                    <div class="tooltip-empty">Нет задач</div>
                                {% else %}
                                    {% for task in dayTasks %}
                                        <div class="tooltip-task-item {% if task.isCompleted %}done{% endif %}">
                                            {{ task.title }}
                                        </div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <a href="{{ path('app_exam_new') }}" class="btn-adjust">Добавить экзамен</a>
            </div>
        </div>
        <div class="calendar-sidebar">
            <div class="calendar-card">
                <h2 class="sidebar-title">План на сегодня</h2>
                {% for task in todayTasks %}
                    <div class="today-task">
                        <input type="checkbox" class="task-checkbox" {% if task.isCompleted %}checked{% endif %} onchange="toggleTask({{ task.id }})">
                        <div class="task-name {% if task.isCompleted %}done{% endif %}">{{ task.title }}</div>
                    </div>
                {% else %}
                    <div class="empty-state">Задач на сегодня нет</div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<div id="taskModal" class="modal">
    <div class="modal-content">
        <h3>Новая задача</h3>
        <input type="hidden" id="taskDate">
        <input type="text" id="taskTitle" placeholder="Название задачи">
        <select id="taskExam">
            <option value="">-- Повседневная задача --</option>
            {% for exam in exams %}
                <option value="{{ exam.id }}">{{ exam.name }}</option>
            {% endfor %}
        </select>
        <button id="saveTaskBtn" class="btn-save-task">Сохранить</button>
        <button onclick="document.getElementById('taskModal').style.display='none'" class="btn-cancel-task">Отмена</button>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/tasks.js') }}"></script>
{% endblock %}