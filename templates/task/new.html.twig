{% extends 'base.html.twig' %}

{% block title %}Добавить задачу{% endblock %}

{% block body %}
<div class="form-page">
    <div class="form-container">
        <h1 class="form-title">Новая задача</h1>
        
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.title) }}
                {{ form_widget(form.title) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.scheduledDate) }}
                {{ form_widget(form.scheduledDate) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.exam) }}
                {{ form_widget(form.exam) }}
            </div>
            
            <button type="submit" class="btn-submit">Создать задачу</button>
        {{ form_end(form) }}
        
        <a href="{{ path('app_tasks') }}" class="btn-back-link">
            <svg width="18" height="18" viewBox="3 3 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 12H5M5 12l6 6M5 12l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Назад к списку
        </a>
</div>
{% endblock %}