{% extends 'base.html.twig' %}

{% block title %}Мои задачи{% endblock %}

{% block body %}
<div class="tasks-page">
    <div class="tasks-header">
        <h1 class="tasks-title">Мои задачи</h1>
        <div class="header-actions">
            <button id="bulkModeBtn" class="btn-bulk-mode">Выбрать для удаления</button>
            <button id="bulkDeleteBtn" class="btn-delete-bulk" style="display: none;">
                Удалить выбранные (<span id="selectedCount">0</span>)
            </button>
            <button id="cancelBulkBtn" class="btn-cancel-bulk" style="display: none;">Отмена</button>
            <a href="{{ path('app_task_new') }}" class="btn-add">+ Добавить задачу</a>
        </div>
    </div>
    
    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    
    {% if tasks|length > 0 %}
        <div class="bulk-select-header" id="bulkSelectHeader" style="display: none;">
            <label class="select-all-label">
                <input type="checkbox" id="selectAllTasks" class="task-select-checkbox">
                <span>Выбрать все</span>
            </label>
        </div>

        {% for task in tasks %}
            <div class="task-card {% if task.isCompleted %}completed{% endif %}" data-task-id="{{ task.id }}">
                <div class="task-checkbox-wrapper normal-mode">
                    <input type="checkbox" class="task-status-checkbox" {% if task.isCompleted %}checked{% endif %} onchange="toggleTask({{ task.id }})" title="Отметить как выполненную">
                </div>
                
                <div class="bulk-mode-checkbox" style="display: none;">
                    <input type="checkbox" class="task-select-checkbox" value="{{ task.id }}">
                </div>
                
                <div class="task-info">
                    <div class="task-title {% if task.isCompleted %}done{% endif %}">{{ task.title }}</div>
                    <div class="task-meta">{{ task.scheduledDate|date('d.m.Y') }}</div>
                    {% if task.exam %}<div class="task-meta">{{ task.exam.name }} ({{ task.exam.subject }})</div>{% endif %}
                    {% if task.description %}<div class="task-meta">{{ task.description|slice(0, 80) }}{% if task.description|length > 80 %}...{% endif %}</div>{% endif %}
                </div>
                
                <div class="task-actions normal-mode">
                    <form method="post" action="{{ path('app_task_delete', {id: task.id}) }}" onsubmit="return confirm('Удалить эту задачу?');" class="delete-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_task_' ~ task.id) }}">
                        <button type="submit" class="btn-delete-single">Удалить</button>
                    </form>
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="empty-state">
            <p>У вас пока нет задач</p>
            <a href="{{ path('app_task_new') }}" class="btn-add">Добавить первую задачу</a>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/tasks.js') }}"></script>
{% endblock %}