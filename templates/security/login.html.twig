{% extends 'base.html.twig' %}

{% block title %}Вход в систему{% endblock %}

{% block body_class %}full-width-layout{% endblock %}

{% block sidebar %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-header">
        <div class="login-icon"></div>
        <h1 class="login-title">Вход</h1>
    </div>
    
    {% if error %}
        <div class="alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}
    
    {% for message in app.flashes('success') %}
        <div class="alert-success">{{ message }}</div>
    {% endfor %}
    
    <form method="post">
        <div class="form-group">
    <label for="inputEmail">Email</label>
    <input type="email" id="inputEmail" name="email" value="{{ last_username }}" required autofocus autocomplete="email">
</div>

<div class="form-group">
    <label for="inputPassword">Пароль</label>
    <input type="password" id="inputPassword" name="password" required autocomplete="current-password">
</div>
        
        <div class="remember-me">
            <input type="checkbox" id="remember" name="_remember_me">
            <label for="remember">Запомнить меня</label>
        </div>
        
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        
        <button type="submit" class="btn-login">Войти</button>
    </form>
    
    <div class="register-link">
        Нет аккаунта? <a href="{{ path('app_register') }}">Зарегистрироваться</a>
    </div>
</div>
{% endblock %}