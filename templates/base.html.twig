<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token('task_action') }}">
    <meta name="user-id" content="{{ app.user ? app.user.id : 'anonymous' }}">
    <title>{% block title %}Умный Календарь{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}">
    <link rel="stylesheet" href="{{ asset('styles/base.css') }}">
    {% block stylesheets %}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">
    <div class="layout">
        {% block sidebar %}
        <aside class="sidebar">
            <div class="sidebar-title">Умный<br>Календарь</div>
            
            <ul class="nav-menu">
                <li class="nav-item">
                    <a href="{{ path('app_home') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">
                        <span class="nav-icon"></span> Главная
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_calendar') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_calendar' %}active{% endif %}">
                        <span class="nav-icon"></span> Календарь
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_tasks') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_tasks' %}active{% endif %}">
                        <span class="nav-icon"></span> Задачи
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_exams') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_exams' %}active{% endif %}">
                        <span class="nav-icon"></span> Экзамены
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_materials') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_materials' %}active{% endif %}">
                        <span class="nav-icon"></span> Материалы
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_avatar') }}" class="nav-link {% if app.request.attributes.get('_route') == 'app_avatar' %}active{% endif %}">
                        <span class="nav-icon"></span> Аватар
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_logout') }}" class="nav-link">
                        <span class="nav-icon"></span> Выйти
                    </a>
                </li>
            </ul>
        </aside>
        {% endblock %}
        
        <main class="main-content">
            {% for type in ['success', 'error'] %}
                {% for message in app.flashes(type) %}
                    <div class="flash-{{ type }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            
            {% block body %}{% endblock %}
        </main>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const flashes = document.querySelectorAll('.flash-success, .flash-error');
        
        flashes.forEach(flash => {
            setTimeout(() => {
                flash.classList.add('fade-out');
                setTimeout(() => flash.remove(), 400);
            }, 3000);
            
            flash.addEventListener('click', function() {
                this.classList.add('fade-out');
                setTimeout(() => this.remove(), 400);
            });
        });
    });
    </script>

<script src="{{ asset('js/global-timer.js') }}"></script>
{% block javascripts %}{% endblock %}

<div id="global-timer-widget" class="global-timer-widget" style="display: none;">
    <span class="widget-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
    </span>
    <span class="widget-time" id="global-timer-time">25:00</span>
    <a href="{{ path('app_home') }}" class="widget-expand">Развернуть</a>
</div>
</body>
</html>