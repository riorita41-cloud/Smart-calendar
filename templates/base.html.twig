<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Умный Календарь{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}">
    <link rel="stylesheet" href="{{ asset('styles/base.css') }}">
    {% block stylesheets %}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">
    <div class="layout">
        {% block sidebar %}
        <aside class="sidebar">
            <div class="sidebar-title">Умный<br>Календарь</div>
            
            <ul class="nav-menu">
    {% set routes = [
        {'name': 'Главная', 'path': 'app_home'},
        {'name': 'Календарь', 'path': 'app_calendar'},
        {'name': 'Экзамены', 'path': 'app_exams'},
        {'name': 'Материалы', 'path': 'app_materials'},
        {'name': 'Аватар', 'path': 'app_avatar'}
    ] %}

    {% for item in routes %}
        <li class="nav-item">
            <a href="{{ path(item.path) }}" class="nav-link {% if app.request.attributes.get('_route') == item.path %}active{% endif %}">
                {{ item.name }}
            </a>
        </li>
    {% endfor %}
    
    <li class="nav-item">
        <a href="{{ path('app_logout') }}" class="nav-link">Выйти</a>
    </li>
</ul>
        </aside>
        {% endblock %}
        
        <main class="main-content">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-{{ type }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            
            {% block body %}{% endblock %}
        </main>
    </div>

    <script src="{{ asset('js/calendar.js') }}"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>