{% extends 'base.html.twig' %}

{% block title %}Загрузка материалов{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/materials-upload.css') }}">
{% endblock %}

{% block body %}
<div class="materials-container">
    <h1 class="page-title">Загрузка материалов</h1>
    
    <div class="flash-messages">
        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error" style="color: red;">{{ message }}</div>
        {% endfor %}
    </div>
    
    <form method="post" action="{{ path('app_materials') }}" enctype="multipart/form-data">
        {# ДОБАВЛЕНА CSRF-ЗАЩИТА #}
        <input type="hidden" name="_token" value="{{ csrf_token('materials_upload') }}">
        
        <div class="upload-grid">
            <div class="upload-card" id="dropZone">
                <div class="upload-icon">📁</div>
                <h2>Загрузить файлы</h2>
                <p class="upload-text">Перетащите файлы сюда</p>
                <p class="supported-formats">PDF, JPG, PNG до 5MB</p>
                <input type="file" name="files[]" id="fileInput" class="file-input-hidden" multiple accept=".pdf,.jpg,.jpeg,.png">
                <button type="button" class="btn-upload" onclick="document.getElementById('fileInput').click()">
                    Выбрать файлы
                </button>
                <div class="file-list" id="fileList"></div>
            </div>
            
            <div class="manual-form">
                <h2>Или введите вручную</h2>
                <textarea name="manualContent" placeholder="Введите вопросы по одному на строку&#10;Например:&#10;1. Что такое алгоритм?"></textarea>
                <button type="submit" class="btn-upload">
                    Сохранить материалы
                </button>
            </div>
        </div>
    </form>
    
    {% if materials|length > 0 %}
    <div class="materials-list">
        <h2>Ваши материалы ({{ materials|length }})</h2>
        {% for material in materials %}
            <div class="material-item">
                <div>
                    <div class="material-name">
                        {{ material.name }}
                    </div>
                    <div class="material-date">
                        Загружено: {{ material.uploadedAt|date('d.m.Y H:i') }}
                    </div>
                </div>
                <div class="material-type">
                    {% if material.fileType == 'manual' %}
                        Ручной ввод
                    {% else %}
                        {{ material.fileType|upper }}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/materials-upload.js') }}"></script>
{% endblock %}