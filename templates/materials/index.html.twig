{% extends 'base.html.twig' %}

{% block title %}Материалы для подготовки{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/materials.css') }}">
{% endblock %}

{% block body %}
<div class="materials-page">
    <div class="page-header">
        <h1 class="page-title">
            <!-- ИСПРАВЛЕНО: stroke="#4A5D3A" вместо #667eea -->
            <svg class="icon-svg icon-title-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="#4A5D3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" stroke="#4A5D3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 7h8" stroke="#4A5D3A" stroke-width="2" stroke-linecap="round"/>
                <path d="M8 11h8" stroke="#4A5D3A" stroke-width="2" stroke-linecap="round"/>
                <path d="M8 15h5" stroke="#4A5D3A" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Материалы для подготовки
        </h1>
        <a href="{{ path('app_material_new') }}" class="btn-add">
            <svg class="icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Добавить материал
        </a>
    </div>
    
    {% if materials|length > 0 %}
        <div class="materials-grid">
            {% for material in materials %}
                <div class="material-card">
                    <div class="material-name">{{ material.name }}</div>
                    <div class="material-meta">Создан: {{ material.uploadedAt|date('d.m.Y H:i') }}</div>
                    
                    <div class="material-stats">
                        <div>
                            <div class="stat-value">{{ material.questions|length }}</div>
                            <div class="stat-label">вопросов</div>
                        </div>
                    </div>
                    
                    <div class="material-actions">
                        <a href="{{ path('app_questions_add', {id: material.id}) }}" class="btn btn-primary">
                            <svg class="icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Добавить вопросы
                        </a>
                        <a href="{{ path('app_material_view', {id: material.id}) }}" class="btn btn-secondary">
                            <svg class="icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Просмотр
                        </a>
                        <form method="post" action="{{ path('app_material_delete', {id: material.id}) }}" style="display: inline;" onsubmit="return confirm('Удалить материал и все его вопросы?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ material.id) }}">
                            <button type="submit" class="btn-outline-danger">
                                <svg class="icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Удалить
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="no-data">
            <svg class="icon-svg" style="width: 64px; height: 64px; margin-bottom: 20px;" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="#D4CFC4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" stroke="#D4CFC4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <h3 style="font-family: Georgia, serif; color: #4A5D3A; margin-bottom: 10px;">Пока нет материалов</h3>
            <p style="color: #6B6B5E; margin-bottom: 20px;">Создайте первый материал и добавьте в него вопросы для подготовки</p>
            <a href="{{ path('app_material_new') }}" class="btn btn-primary">
                <svg class="icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Создать материал
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}