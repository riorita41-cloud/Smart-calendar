{% extends 'base.html.twig' %}

{% block title %}Загрузка материалов{% endblock %}

{% block body %}
<style>
    .materials-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 20px;
    }
    
    .page-title {
        font-size: 32px;
        color: #4A5D3A;
        margin-bottom: 30px;
        text-align: center;
        font-family: Georgia, serif;
    }
    
    .upload-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        margin-bottom: 40px;
    }
    
    .upload-card {
        background: #FAF7F0;
        border-radius: 16px;
        padding: 30px;
        border: 2px dashed #D4CFC4;
        text-align: center;
        transition: all 0.3s;
    }
    
    .upload-card h2 {
        color: #4A5D3A;
        margin-bottom: 20px;
        font-family: Georgia, serif;
    }
    
    .upload-icon {
        font-size: 64px;
        margin-bottom: 15px;
    }
    
    .upload-text {
        color: #6B6B5E;
        margin-bottom: 20px;
        font-size: 16px;
    }
    
    .supported-formats {
        color: #94A3B8;
        font-size: 14px;
        margin-bottom: 20px;
    }
    
    .btn-upload {
        background: #4A5D3A;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-size: 16px;
        cursor: pointer;
        font-family: Georgia, serif;
        margin-top: 10px;
    }
    
    .btn-upload:hover {
        background: #3A4A2D;
    }
    
    .manual-form {
        background: #FAF7F0;
        border-radius: 16px;
        padding: 30px;
        border: 1px solid #D4CFC4;
    }
    
    .manual-form h2 {
        color: #4A5D3A;
        margin-bottom: 20px;
        font-family: Georgia, serif;
    }
    
    .manual-form textarea {
        width: 100%;
        min-height: 200px;
        padding: 15px;
        border: 1px solid #D4CFC4;
        border-radius: 8px;
        font-family: Georgia, serif;
        font-size: 14px;
        resize: vertical;
        margin-bottom: 20px;
        box-sizing: border-box;
    }
    
    .materials-list {
        margin-top: 40px;
    }
    
    .materials-list h2 {
        color: #4A5D3A;
        margin-bottom: 20px;
        font-family: Georgia, serif;
    }
    
    .material-item {
        background: #FAF7F0;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #D4CFC4;
    }
    
    .material-name {
        color: #4A5D3A;
        font-family: Georgia, serif;
        font-weight: bold;
    }
    
    .material-date {
        color: #94A3B8;
        font-size: 14px;
        margin-top: 5px;
    }
    
    .material-type {
        background: #4A5D3A;
        color: #FAF7F0;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-family: Georgia, serif;
    }
    
    .flash-messages {
        margin-bottom: 20px;
    }
    
    .flash-success {
        background: #90CC74;
        color: white;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 10px;
        font-family: Georgia, serif;
    }
    
    .file-input-hidden {
        display: none;
    }
    
    .file-list {
        margin-top: 15px;
        text-align: left;
        color: #6B6B5E;
        font-family: Georgia, serif;
    }
</style>

<div class="materials-container">
    <h1 class="page-title">Загрузка материалов</h1>
    
    <div class="flash-messages">
        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
    </div>
    
    <form method="post" action="{{ path('app_materials') }}" enctype="multipart/form-data">
        <div class="upload-grid">
            <div class="upload-card" id="dropZone">
                <div class="upload-icon">📁</div>
                <h2>Загрузить файлы</h2>
                <p class="upload-text">Перетащите файлы сюда</p>
                <p class="supported-formats">PDF, DOCX, TXT до 10MB</p>
                <input type="file" name="files[]" id="fileInput" class="file-input-hidden" multiple accept=".pdf,.txt,.docx,.doc">
                <button type="button" class="btn-upload" onclick="document.getElementById('fileInput').click()">
                    Выбрать файлы
                </button>
                <div class="file-list" id="fileList"></div>
            </div>
            
            <div class="manual-form">
                <h2>Или введите вручную</h2>
                <textarea name="manualContent" placeholder="Введите вопросы по одному на строку&#10;Например:&#10;1. Что такое алгоритм?&#10;2. Какие виды сортировок вы знаете?&#10;3. Что такое рекурсия?"></textarea>
                <button type="submit" class="btn-upload">
                    Сохранить материалы
                </button>
            </div>
        </div>
    </form>
    
    {% if materials|length > 0 %}
    <div class="materials-list">
        <h2>Ваши материалы ({{ materials|length }})</h2>
        {% for material in materials %}
            <div class="material-item">
                <div>
                    <div class="material-name">
                        {{ material.name }}
                    </div>
                    <div class="material-date">
                        Загружено: {{ material.uploadedAt|date('d.m.Y H:i') }}
                    </div>
                </div>
                <div class="material-type">
                    {% if material.fileType == 'manual' %}
                        Ручной ввод
                    {% else %}
                        {{ material.fileType|upper }}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

<script>
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
const fileList = document.getElementById('fileList');

if (dropZone && fileInput) {
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, preventDefaults, false);
    });
    
    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }
    
    ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => {
            dropZone.style.borderColor = '#6366F1';
            dropZone.style.background = '#E8E4FF';
        }, false);
    });
    
    ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => {
            dropZone.style.borderColor = '#D4CFC4';
            dropZone.style.background = '#FAF7F0';
        }, false);
    });
    
    dropZone.addEventListener('drop', (e) => {
        const files = e.dataTransfer.files;
        if (files.length > 0) {
            fileInput.files = files;
            updateFileList(files);
        }
    }, false);
    
    fileInput.addEventListener('change', (e) => {
        updateFileList(e.target.files);
    });
    
    function updateFileList(files) {
        fileList.innerHTML = '<strong>Выбрано файлов:</strong><br>';
        for (let file of files) {
            fileList.innerHTML += '📄 ' + file.name + '<br>';
        }
    }
}
</script>
{% endblock %}