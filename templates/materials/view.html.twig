{% extends 'base.html.twig' %}

{% block title %}{{ material.name }} - Вопросы{% endblock %}

{% block body %}
<style>
    .view-page { max-width: 900px; margin: 40px auto; padding: 0 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .page-title { font-size: 24px; color: #4A5D3A; font-family: Georgia, serif; margin: 0; }
    .back-link { color: #667eea; text-decoration: none; font-family: Georgia, serif; }
    .back-link:hover { text-decoration: underline; }
    
    .questions-list { background: white; border-radius: 12px; border: 1px solid #E8E4D8; overflow: hidden; }
    .question-item { padding: 20px; border-bottom: 1px solid #F5F1E8; transition: background 0.2s; }
    .question-item:last-child { border-bottom: none; }
    .question-item:hover { background: #FAF7F0; }
    
    .question-number { display: inline-block; background: #667eea; color: white; width: 28px; height: 28px; border-radius: 50%; text-align: center; line-height: 28px; font-weight: bold; font-size: 14px; margin-right: 12px; }
    .question-text { font-size: 16px; color: #2C2C2C; font-family: Georgia, serif; margin-bottom: 8px; }
    .answer-box { background: #F0F4FF; border-left: 3px solid #667eea; padding: 12px; margin-top: 10px; border-radius: 6px; }
    .answer-label { font-size: 12px; color: #667eea; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; }
    .answer-text { font-size: 15px; color: #4A5568; font-family: Georgia, serif; }
    
    .stats-bar { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; background: #FAF7F0; border-radius: 8px; margin-bottom: 20px; }
    .stats-text { font-family: Georgia, serif; color: #4A5D3A; }
    .stats-text strong { color: #667eea; }
    
    .no-questions { text-align: center; padding: 60px 20px; color: #6B6B5E; font-family: Georgia, serif; }
</style>

<div class="view-page">
    <div class="page-header">
        <h1 class="page-title">{{ material.name }}</h1>
        <div>
            <a href="{{ path('app_questions_add', {id: material.id}) }}" class="back-link">➕ Добавить ещё</a>
            <span style="margin: 0 10px; color: #D4CFC4;">|</span>
            <a href="{{ path('app_materials') }}" class="back-link">← К материалам</a>
        </div>
    </div>
    
    <div class="stats-bar">
        <div class="stats-text">Всего вопросов: <strong>{{ questions|length }}</strong></div>
        <div class="stats-text">Материал создан: {{ material.uploadedAt|date('d.m.Y H:i') }}</div>
    </div>
    
    {% if questions|length > 0 %}
        <div class="questions-list">
            {% for question in questions %}
                <div class="question-item">
                    <div class="question-text">
                        <span class="question-number">{{ loop.index }}</span>
                        {{ question.text }}
                    </div>
                    {% if question.answer %}
                        <div class="answer-box">
                            <div class="answer-label">Ответ:</div>
                            <div class="answer-text">{{ question.answer }}</div>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="no-questions">
            <h3>Пока нет вопросов</h3>
            <p>Добавьте вопросы, чтобы начать подготовку</p>
            <a href="{{ path('app_questions_add', {id: material.id}) }}" class="back-link">Добавить вопросы →</a>
        </div>
    {% endif %}
</div>
{% endblock %}