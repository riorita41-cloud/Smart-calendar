{% extends 'base.html.twig' %}

{% block title %}{{ material.name }} - Вопросы{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/materials.css') }}">
{% endblock %}

{% block body %}
<div class="question-view-page">
    <div class="question-page-header">
        <h1 class="question-page-title">{{ material.name }}</h1>
        <div>
            <a href="{{ path('app_questions_add', {id: material.id}) }}" class="question-back-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Добавить ещё
            </a>
            <span style="margin: 0 10px; color: var(--color-border);">|</span>
            <a href="{{ path('app_materials') }}" class="question-back-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 12H5M5 12l6 6M5 12l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                К материалам
            </a>
        </div>
    </div>
    
    <div class="stats-bar">
        <div class="stats-text">Всего вопросов: <strong>{{ questions|length }}</strong></div>
        <div class="stats-text">Материал создан: {{ material.uploadedAt|date('d.m.Y H:i') }}</div>
    </div>
    
    {% if questions|length > 0 %}
        <div class="questions-list">
            {% for question in questions %}
                <div class="question-item">
                    <div class="question-number-wrapper">
                        <span class="question-number">{{ loop.index }}</span>
                        <div class="question-text">{{ question.text }}</div>
                    </div>
                    {% if question.answer %}
                        <div class="answer-box">
                            <div class="answer-label">Ответ:</div>
                            <div class="answer-text">{{ question.answer }}</div>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="no-questions">
            <h3>Пока нет вопросов</h3>
            <p>Добавьте вопросы, чтобы начать подготовку</p>
            <a href="{{ path('app_questions_add', {id: material.id}) }}" class="question-back-link">
                Добавить вопросы →
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}