{% extends 'base.html.twig' %}

{% block title %}Новый материал{% endblock %}

{% block body %}
<style>
    .form-page { max-width: 600px; margin: 40px auto; padding: 30px; background: white; border-radius: 16px; border: 1px solid #E8E4D8; }
    .form-title { font-size: 24px; color: #4A5D3A; font-family: Georgia, serif; margin-bottom: 25px; text-align: center; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; color: #4A5D3A; font-family: Georgia, serif; font-weight: bold; }
    .form-control { width: 100%; padding: 12px; border: 1px solid #D4CFC4; border-radius: 8px; font-family: Georgia, serif; font-size: 15px; box-sizing: border-box; }
    .form-control:focus { outline: none; border-color: #667eea; }
    .btn-submit { width: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 14px; border-radius: 8px; font-family: Georgia, serif; font-size: 16px; cursor: pointer; transition: all 0.2s; }
    .btn-submit:hover { opacity: 0.9; }
    .back-link { display: block; text-align: center; margin-top: 20px; color: #6B6B5E; text-decoration: none; font-family: Georgia, serif; }
    .back-link:hover { text-decoration: underline; }
</style>

<div class="form-page">
    <h1 class="form-title">Создание нового материала</h1>
    
    {{ form_start(form) }}
        <div class="form-group">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>
        
        <div class="form-group">
            {{ form_label(form.exam) }}
            {{ form_widget(form.exam) }}
            {{ form_errors(form.exam) }}
        </div>
        
        <button type="submit" class="btn-submit">Создать и перейти к вопросам</button>
    {{ form_end(form) }}
    
    <a href="{{ path('app_materials') }}" class="back-link">← Вернуться к списку</a>
</div>
{% endblock %}