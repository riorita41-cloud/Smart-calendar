{% extends 'base.html.twig' %}

{% block title %}Добавить вопросы - {{ material.name }}{% endblock %}

{% block body %}
<style>
    .questions-page { max-width: 800px; margin: 40px auto; padding: 0 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .page-title { font-size: 24px; color: #4A5D3A; font-family: Georgia, serif; margin: 0; }
    .back-link { color: #667eea; text-decoration: none; font-family: Georgia, serif; }
    .back-link:hover { text-decoration: underline; }
    
    .hint-box { background: #F0F4FF; border-left: 4px solid #667eea; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-family: Georgia, serif; color: #4A5568; }
    .hint-box strong { color: #667eea; }
    
    .form-box { background: white; padding: 25px; border-radius: 12px; border: 1px solid #E8E4D8; }
    textarea.questions-input {
        width: 100%; min-height: 300px; padding: 15px; border: 1px solid #D4CFC4; border-radius: 8px;
        font-family: monospace; font-size: 14px; line-height: 1.6; resize: vertical; box-sizing: border-box;
    }
    textarea.questions-input:focus { outline: none; border-color: #667eea; }
    
    .btn-save { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 14px 28px; border-radius: 8px; font-family: Georgia, serif; font-size: 16px; cursor: pointer; margin-top: 15px; }
    .btn-save:hover { opacity: 0.9; }
</style>

<div class="questions-page">
    <div class="page-header">
        <h1 class="page-title">Добавить вопросы: {{ material.name }}</h1>
        <a href="{{ path('app_materials') }}" class="back-link">← К материалам</a>
    </div>
    
    <div class="hint-box">
        💡 <strong>Подсказка:</strong> Вставьте вопросы по одному на строку.<br>
        Если у вопроса есть ответ, отделите его словом <strong>Ответ:</strong> или символом <strong>|</strong>.<br>
        <em>Пример: Что такое PHP? Ответ: Язык программирования</em><br>
        <em>Пример: Сколько будет 2+2? | 4</em>
    </div>
    
    <div class="form-box">
        <form method="post">
            <textarea name="questions" class="questions-input" placeholder="Вставьте ваши вопросы сюда...&#10;1. Первый вопрос? Ответ: Первый ответ&#10;2. Второй вопрос? | Второй ответ"></textarea>
            <button type="submit" class="btn-save">💾 Сохранить вопросы</button>
        </form>
    </div>
    
    {% if material.questions|length > 0 %}
        <div style="margin-top: 30px;">
            <h3 style="font-family: Georgia, serif; color: #4A5D3A;">Уже добавлено вопросов: {{ material.questions|length }}</h3>
            <a href="{{ path('app_material_view', {id: material.id}) }}" class="back-link">Посмотреть все вопросы →</a>
        </div>
    {% endif %}
</div>
{% endblock %}