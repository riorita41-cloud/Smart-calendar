{% extends 'base.html.twig' %}

{% block title %}Добавить вопросы - {{ material.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/materials.css') }}">
{% endblock %}

{% block body %}
<div class="add-questions-page">
    <div class="questions-page-header">
        <h1 class="questions-page-title">
            Добавить вопросы: {{ material.name }}
        </h1>
        <a href="{{ path('app_materials') }}" class="questions-back-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 12H5M5 12l6 6M5 12l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            К материалам
        </a>
    </div>
    
    <div class="hint-box">
        <div class="hint-box-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Подсказка:
        </div>
        <div>
            Вставьте вопросы по одному на строку.<br>
            Если у вопроса есть ответ, отделите его словом <strong>Ответ:</strong> или символом <strong>|</strong>.<br>
            <em>Пример: Что такое PHP? Ответ: Язык программирования</em><br>
        </div>
    </div>
    
    {% for message in app.flashes('error') %}
        <div class="validation-error-box" style="background: #FEE2E2; border-left: 4px solid #DC2626; padding: 20px; border-radius: 10px; margin-bottom: 20px; font-family: Georgia, serif;">
            <h3 style="color: #DC2626; margin: 0 0 15px 0; font-size: 18px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Найдены ошибки в формате вопросов:
            </h3>
            <div style="color: #7F1D1D; line-height: 1.8;">
                {{ message|raw }}
            </div>
            <p style="margin: 15px 0 0 0; color: #7F1D1D; font-size: 14px; background: rgba(255,255,255,0.5); padding: 10px; border-radius: 6px;">
                <strong>Правильный формат:</strong><br>
                • Вопрос? Ответ: правильный ответ<br>
                • Вопрос? | правильный ответ
            </p>
        </div>
    {% endfor %}
    
    <div class="questions-form-box">
        <form method="post">
            <textarea name="questions" class="questions-textarea" placeholder="Вставьте ваши вопросы сюда...&#10;1. Первый вопрос? Ответ: Первый ответ&#10;2. Второй вопрос? | Второй ответ"></textarea>
            <button type="submit" class="questions-save-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Сохранить вопросы
            </button>
        </form>
    </div>
    
    {% if material.questions|length > 0 %}
        <div class="existing-questions-section">
            <div class="existing-questions-title">
                Уже добавлено вопросов: <span class="existing-questions-count">{{ material.questions|length }}</span>
            </div>
            <a href="{{ path('app_material_view', {id: material.id}) }}" class="view-questions-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Посмотреть все вопросы
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/validate-questions.js') }}"></script>
{% endblock %}